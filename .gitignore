# =========================

# ROOT LEVEL (FULL STACK)

# =========================

# OS files

.DS_Store
Thumbs.db

# Logs

*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables (IMPORTANT)

.env
.env.*
!.env.example

# Dependency directories

node_modules/
frontend/node_modules/
backend/node_modules/

# Build outputs

dist/
build/
frontend/build/
frontend/dist/
backend/dist/

# Cache / temp

.cache/
.tmp/
temp/
tmp/

# IDE / Editors

.vscode/
.idea/
*.swp
*.swo

# Coverage

coverage/

# =========================

# FRONTEND (React)

# =========================

# React env files

frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# React build artifacts

frontend/build/
frontend/dist/

# =========================

# BACKEND (Express)

# =========================

# Runtime files

backend/*.pid
backend/*.seed
backend/*.pid.lock

# Logs

backend/logs/

# Uploads (if any)

backend/uploads/

# =========================

# DATABASE / FILES

# =========================

# DB dumps / backups

*.dump
*.bak
*.sql

# =========================

# AUTOMATION / SESSIONS (for your project)

# =========================

# Tokens / sessions (VERY IMPORTANT)

session/
sessions/
cookies/
tokens.json

# Webhook logs / temp data

webhook-logs/

# =========================

# TYPESCRIPT (if used later)

# =========================

*.tsbuildinfo
